@startuml
class Product {
  - id : String
  - name : String
  - category : Category
  - price : double
  - quantity : int
  + Product(id: String, name: String, category: Category, price: double, quantity: int)
  + getId() : String
  + getName() : String
  + getCategory() : Category
  + getPrice() : double
  + setPrice(p: double) : void
  + getQuantity() : int
  + setQuantity(q: int) : void
  + increaseQuantity(delta: int) : void
  + decreaseQuantity(delta: int) : void
  + getInventoryValue() : double
}

enum Category {
  DAIRY
  BAKERY
  PRODUCE
  BEVERAGE
  OTHER
}

class InventoryManager {
  - products : List<Product>
  - storage : StorageManager
  + InventoryManager()
  + addProduct(p: Product) : boolean
  + updateProduct(p: Product) : boolean
  + removeProduct(productId: String) : boolean
  + findProductById(productId: String) : Product
  + listProducts() : List<Product>
  + restockProduct(productId: String, amount: int) : boolean
  + recordSale(productId: String, amount: int) : boolean
  + getTotalInventoryValue() : double
  + loadFromStorage() : void
  + saveToStorage() : void
}

class StorageManager {
  - filePath : String
  + StorageManager(filePath: String)
  + save(products: List<Product>) : void
  + load() : List<Product)
}

class MainMenuUI {
  - inventory : InventoryManager
  + MainMenuUI(inventory: InventoryManager)
  + show() : void
  + openManageProducts() : void
  + openUpdateStock() : void
  + openViewInventory() : void
}

class ManageProductsUI {
  - inventory : InventoryManager
  - selectedProduct : Product
  + ManageProductsUI(inventory: InventoryManager)
  + show() : void
  + onAddClick(formData: Map<String,Object>) : void
  + onUpdateClick(formData: Map<String,Object>) : void
  + onDeleteClick(productId: String) : void
  + renderTable() : void
}

class UpdateStockUI {
  - inventory : InventoryManager
  - selectedProduct : Product
  + UpdateStockUI(inventory: InventoryManager)
  + show() : void
  + onRestockClick(productId: String, amount: int) : void
  + onRecordSaleClick(productId: String, amount: int) : void
}

class InventoryViewUI {
  - inventory : InventoryManager
  + InventoryViewUI(inventory: InventoryManager)
  + show() : void
  + renderTable() : void
  + showProductDetails(productId: String) : void
}

InventoryManager "1" *-- "0..*" Product
InventoryManager o-- StorageManager
MainMenuUI --> InventoryManager
ManageProductsUI --> InventoryManager
UpdateStockUI --> InventoryManager
InventoryViewUI --> InventoryManager
ManageProductsUI --> Product
UpdateStockUI --> Product
InventoryViewUI --> Product
@enduml